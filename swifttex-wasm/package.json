{
  "name": "swifttex-wasm",
  "version": "0.4.0",
  "description": "Fast LaTeX math rendering engine — Rust/WASM",
  "main": "pkg/swifttex.js",
  "types": "pkg/swifttex.d.ts",
  "style": "style.css",
  "files": ["pkg/", "react/", "web-component/", "vue/", "svelte/", "style.css"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/LikhinMN/swifttex"
  },
  "keywords": ["latex", "math", "wasm", "katex", "mathjax", "rendering"],
  "exports": {
    ".": {
      "types": "./pkg/swifttex.d.ts",
      "default": "./pkg/swifttex.js"
    },
    "./react": {
      "types": "./react/index.d.ts",
      "default": "./react/index.js"
    },
    "./web-component": {
      "types": "./web-component/index.d.ts",
      "default": "./web-component/index.js"
    },
    "./vue": "./vue/SwiftTeX.vue",
    "./svelte": "./svelte/SwiftTeX.svelte"
  },
  "peerDependencies": {
    "react": "^16.8.0 || ^17.0.0 || ^18.0.0 || ^19.0.0"
  }
}
